# Database Driver Selector: mysql, sqlite, or mongodb
DB_DRIVER=sqlite

# --- MySQL / MariaDB Config ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=inventory_db
DB_USER=root
DB_PASS=

# --- SQLite Config ---
# Path relative to the project root
DB_FILE=inventory.db

# --- MongoDB Config ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=inventory_db
